# Sample environment file for the JIRA → AAP → EC2 + Zabbix demo.
# Copy to .env (git-ignored) and fill in real values:  cp .env.example .env
# Structure inherited from redhat-telco-adoption/aap-eda-demo, extended for JIRA.

# === AWS ===
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-2

# === SSH ===
AWS_KEY_PAIR_NAME=demo-key
AWS_PRIVATE_KEY_PATH=keys/demo-key.pem

# === Compute ===
# RHEL 9 AMIs for us-east-2 (Red Hat owner 309956199498) — update to latest
ZABBIX_AMI=ami-08d2f096f70b3dd74
ZABBIX_INSTANCE_TYPE=t3.medium
# AMI for ticket-provisioned VMs (instance type comes from the JIRA ticket)
VM_AMI=ami-08d2f096f70b3dd74
VM_DEFAULT_INSTANCE_TYPE=t3.micro

# === RDS (Zabbix database) ===
RDS_INSTANCE_CLASS=db.m5.large
RDS_MASTER_USERNAME=postgres
RDS_MASTER_PASSWORD=change-me-rds

# === OpenShift (cluster hosting AAP) ===
OPENSHIFT_API_URL=https://api.your-cluster.example.com:6443
OPENSHIFT_USERNAME=admin
OPENSHIFT_PASSWORD=change-me-ocp
# Alternative to username/password:
# KUBECONFIG=path/to/kubeconfig

# === AAP (on OpenShift) ===
# AAP 2.5 uses the Gateway as the single API entry point for Controller and EDA
AAP_GATEWAY_URL=https://gateway.apps.your-cluster.example.com
AAP_ADMIN_USERNAME=admin
AAP_ADMIN_PASSWORD=change-me-aap
AAP_ADMIN_TOKEN=your-api-token   # optional, alternative to user/pass

# === Red Hat Automation Hub ===
# Offline token from https://console.redhat.com/ansible/automation-hub/token
AUTOMATION_HUB_TOKEN=REPLACE_WITH_AUTOMATION_HUB_TOKEN

# === Zabbix ===
ZABBIX_ADMIN_PASSWORD=change-me-zabbix
ZABBIX_DB_PASSWORD=change-me-zabbix-db

# === EDA Event Stream (JIRA → EDA webhook) ===
# Basic auth credentials for the Basic Event Stream credential in AAP;
# the JIRA Automation rule sends these in its Authorization header
EDA_STREAM_USERNAME=jira
EDA_STREAM_PASSWORD=change-me-eda-stream

# === JIRA Cloud ===
JIRA_URL=https://jlmayorga.atlassian.net
JIRA_EMAIL=you@example.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=REPLACE_WITH_JIRA_API_TOKEN
JIRA_PROJECT_KEY=VMREQ
# Optional — auto-discovered from ${JIRA_URL}/_edge/tenant_info if left empty;
# required by the Automation Rule Management API base path
JIRA_CLOUD_ID=
# Custom field IDs — printed by jira_bootstrap.yml after it creates the fields
JIRA_FIELD_INSTANCE_SIZE=customfield_10xxx
JIRA_FIELD_ENVIRONMENT=customfield_10xxx

# === DNS (Route53) ===
BASE_DOMAIN=sandbox0000.opentlc.com

# === Demo repo (pulled by AAP project sync) ===
DEMO_REPO_URL=https://github.com/redhat-telco-adoption/aap-eda-demo.git
# GitHub Personal Access Token with repo read scope — for private repo access
GITHUB_TOKEN=REPLACE_WITH_GITHUB_PAT
